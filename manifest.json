{
  "manifest_version": 3,
  "name": "Gmail Auto-Unsubscribe",
  "version": "1.0",
  "description": "Automatically detect and unsubscribe from newsletters in Gmail",
  "permissions": ["identity", "storage", "scripting", "tabs", "alarms"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://gmail.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Gmail Auto-Unsubscribe"
  },
  "oauth2": {
    "client_id": "482337979041-ji62dkbrk811d51srue275mcoc55lgek.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.modify"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}